{
  "name": "vibe-coding-tool",
  "version": "1.0.0",
  "description": "Frontend development tool with preview and PR generation",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsc -p src/server/tsconfig.server.json && node dist/server/index.js",
    "build": "tsc && vite build",
    "build:server": "tsc -p src/server/tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.20.0",
    "tar": "^6.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/tar": "^6.1.10",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
